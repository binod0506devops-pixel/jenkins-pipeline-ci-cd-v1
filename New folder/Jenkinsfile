pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/binod0506devops-pixel/jenkins-pipeline-ci-cd-v1.git'
            }
        }

        stage('Build') {
            steps {
                dir('New folder') {
                    sh 'mvn clean package'
                }
            }
        }

    }   // closes stages

    post {
        always {
            echo 'Pipeline finished.'
        }
    }
}