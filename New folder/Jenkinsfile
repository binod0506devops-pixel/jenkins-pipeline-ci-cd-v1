pipeline {
    agent any

    options {
        // Prevent pipeline from running indefinitely
        timeout(time: 10, unit: 'MINUTES')

        // Prevent multiple builds of the same job from running simultaneously
        disableConcurrentBuilds()
    }

    stages {

        // ------------------------------------------------------------------
        // Stage 1: Checkout Source Code
        // Pull the latest application source code from GitHub repository
        // ------------------------------------------------------------------
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/binod0506devops-pixel/jenkins-pipeline-ci-cd-v1.git'
            }
        }

        // ------------------------------------------------------------------
        // Stage 2: Build Application
        // Compile source code and generate deployable artifact (JAR file)
        // ------------------------------------------------------------------
        stage('Build') {
            steps {
                dir('New folder') {
                    sh 'mvn clean package'
                }
            }
        }

        // ------------------------------------------------------------------
        // Stage 3: Execute Unit Tests
        // Run application unit tests to validate functionality
        // ------------------------------------------------------------------
        stage('Unit Testing') {
            steps {
                dir('New folder') {
                    sh 'mvn test'
                }
            }
        }

        // ------------------------------------------------------------------
        // Stage 4: Static Code Analysis
        // Scan source code using SonarQube for code quality,
        // bugs, vulnerabilities, and code smells
        // ------------------------------------------------------------------
        stage('Static Code Analysis') {
            steps {
                dir('New folder') {
                    withSonarQubeEnv('SonarQube servers') {
                        sh '''
                            echo "Running SonarQube Analysis..."

                            mvn sonar:sonar \
                            -Dsonar.projectKey=jenkins-pipeline-project \
                            -Dsonar.projectName=jenkins-pipeline-project
                        '''
                    }
                }
            }
        }

        // ------------------------------------------------------------------
        // Stage 5: SonarQube Environment Verification
        // Validate SonarQube environment variables injected by Jenkins
        // Useful for troubleshooting connectivity issues
        // ------------------------------------------------------------------
        stage('Debug Sonar') {
            steps {
                withSonarQubeEnv('SonarQube servers') {
                    sh '''
                        env | grep SONAR
                    '''
                }
            }
        }

        // ------------------------------------------------------------------
        // Stage 6: Verify Docker Build Context
        // Confirm Dockerfile, application artifacts,
        // and required files are available before image creation
        // ------------------------------------------------------------------
        stage('Verify Dockerfile') {
            steps {
                dir('New folder') {
                    sh '''
                        echo "Current Working Directory:"
                        pwd

                        echo "Listing Project Files:"
                        ls -ltr

                        echo "Verifying Generated JAR File:"
                        ls -ltr target/*.jar
                    '''
                }
            }
        }

        // ------------------------------------------------------------------
        // Stage 7: Build Docker Image
        // Package application into a Docker container image
        // Tag image using Jenkins build number for traceability
        // ------------------------------------------------------------------
        stage('Docker Image Build') {
            steps {
                dir('New folder') {
                    sh '''
                        echo "Building Docker Image..."

                        docker build \
                        -t binod0506/jenkins-pipeline-project:${BUILD_NUMBER} \
                        .
                    '''
                }
            }
        }

        // ------------------------------------------------------------------
        // Stage 8: Push Docker Image to Docker Hub
        // Authenticate with Docker Hub using Jenkins credentials
        // and push the versioned image to remote registry
        // ------------------------------------------------------------------
        stage('Docker Push') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                        echo "Authenticating to Docker Hub..."

                        echo "$DOCKER_PASS" | docker login \
                        -u "$DOCKER_USER" \
                        --password-stdin

                        echo "Pushing Docker Image to Docker Hub..."

                        docker push \
                        binod0506/jenkins-pipeline-project:${BUILD_NUMBER}
                    '''
                }
            }
        }
    }

    post {

        // Execute regardless of pipeline result
        always {
            echo 'Pipeline execution completed.'
        }

        // Execute when pipeline succeeds
        success {
            echo 'CI Pipeline completed successfully.'
        }

        // Execute when pipeline fails
        failure {
            echo 'CI Pipeline execution failed. Please review build logs.'
        }
    }
}