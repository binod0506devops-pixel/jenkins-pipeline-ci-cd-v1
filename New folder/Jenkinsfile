pipeline {
    agent any

    options {
        timeout(time: 10, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // Stage 1: Source Code Checkout
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/binod0506devops-pixel/jenkins-pipeline-ci-cd-v1.git'
            }
        }

        // Stage 2: Build
        stage('Build') {
            steps {
                dir('New folder') {
                    sh 'mvn clean package'
                }
            }
        }

        // Stage 3: Unit Testing
        stage('Unit Testing') {
            steps {
                dir('New folder') {
                    sh 'mvn test'
                }
            }
        }

        // You can add more stages below, like SonarQube, Docker, etc.

    }

    post {
        always {
            echo 'Pipeline finished.'
        }
    }
}